// Prisma schema for BlissTribe
// 对齐 docs/DATABASE.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id              BigInt   @id @default(autoincrement())
  phoneCiphertext Bytes
  phoneHash       String   @unique
  phoneMasked     String
  nickname        String
  avatar          String   @default("")
  gender          Int      @default(0) // 0保密 1男 2女
  birthday        DateTime?
  passwordHash    String?
  inviteCode      String?  @unique // 个人邀请码
  invitedBy       BigInt?  // 邀请人ID
  realName        String?  // 真实姓名
  wechatId        String?  // 微信号
  email           String?  // 邮箱
  age             Int?     // 年龄
  favoriteColor   String?  // 喜欢的颜色
  occupation      String?  // 职业
  tags            String[] // 用户自我标签
  identity        String?  // 注册身份: C/B/S
  level           String   @default("normal") // 注册级别
  douyinPayCode   String?  // 收款码(抖音)
  status          Int      @default(1) // 0禁用 1正常 2待完善
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  wechatAccount WechatAccount?
  sessions      UserSession[]
  agreements    UserAgreement[]
  sentInvitations     MemberInvitation[] @relation("Inviter")
  receivedInvitations MemberInvitation[] @relation("Invitee")
  inviterUser   User?    @relation("UserInvitedBy", fields: [invitedBy], references: [id])
  invitees      User[]   @relation("UserInvitedBy")

  @@index([status])
  @@index([createdAt])
  @@index([inviteCode])
  @@index([invitedBy])
}

// 微信账号表
model WechatAccount {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt   @unique
  wxOpenIdHash  String   @unique
  wxUnionId     String?
  wxNickname    String?
  wxAvatar      String?
  wxGender      Int      @default(0)
  wxCountry     String?
  wxProvince    String?
  wxCity        String?
  status        Int      @default(1) // 0解绑 1绑定
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([wxUnionId])
}

// 用户会话表
model UserSession {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt
  jti               String   @unique
  refreshTokenHash  String
  expiresAt         DateTime
  refreshExpiresAt  DateTime
  ipAddress         String?
  userAgent         String?
  platform          String?
  status            Int      @default(1) // 0失效 1有效
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// 用户注册临时表
model UserRegisterTemp {
  id              BigInt   @id @default(autoincrement())
  tempToken       String   @unique
  wxOpenIdHash    String?
  wxUnionId       String?
  wxNickname      String?
  wxAvatar        String?
  wxGender        Int      @default(0)
  phoneCiphertext Bytes?
  phoneHash       String?
  phoneMasked     String?
  status          Int      @default(1)
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([expiresAt])
}

// 用户协议记录表
model UserAgreement {
  id               BigInt   @id @default(autoincrement())
  userId           BigInt
  agreementType    String // user / privacy
  agreementVersion String
  agreedAt         DateTime
  ipAddress        String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agreedAt])
}

// 协议版本表
model Agreement {
  id          BigInt   @id @default(autoincrement())
  type        String // user / privacy
  version     String
  title       String
  content     String
  isCurrent   Boolean  @default(false)
  effectiveAt DateTime
  createdAt   DateTime @default(now())

  @@unique([type, version])
  @@index([type, isCurrent])
}

// 会员邀请记录表
model MemberInvitation {
  id          BigInt   @id @default(autoincrement())
  inviterId   BigInt   // 邀请人
  inviteeId   BigInt?  // 被邀请人（注册后填充）
  inviteCode  String   // 使用的邀请码
  status      Int      @default(0) // 0待注册 1已注册 2已入会
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inviter User  @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User? @relation("Invitee", fields: [inviteeId], references: [id], onDelete: SetNull)

  @@index([inviterId])
  @@index([inviteeId])
  @@index([inviteCode])
  @@index([status])
}

// Banner 轮播图表
model Banner {
  id          BigInt   @id @default(autoincrement())
  title       String
  description String   @default("")
  imageUrl    String   @default("")
  gradient    String   @default("")
  linkUrl     String   @default("")
  sort        Int      @default(0)
  status      Int      @default(1) // 0下线 1上线
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, sort])
}

// 管理员表（后台独立账号体系）
model Admin {
  id           BigInt   @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  nickname     String
  avatar       String   @default("")
  status       Int      @default(1) // 0禁用 1正常
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  adminRoles AdminRole[]
}

// 角色
model Role {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique // super_admin / admin / operator
  name      String
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admins      AdminRole[]
  permissions RolePermission[]
}

// 管理员-角色关联
model AdminRole {
  adminId BigInt
  roleId  BigInt
  assignedAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminId, roleId])
}

// 权限
model Permission {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique // user:read / user:write / agreement:publish
  name      String
  createdAt DateTime @default(now())

  roles RolePermission[]
}

// 角色-权限关联
model RolePermission {
  roleId       BigInt
  permissionId BigInt
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}
