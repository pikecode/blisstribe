# API 配置
# 数据库连接
DATABASE_URL=postgresql://blisstribe:blisstribe@localhost:5432/blisstribe?schema=public
# Redis
REDIS_URL=redis://localhost:6379
# JWT
JWT_ACCESS_SECRET=change-me-access-secret-32chars
JWT_REFRESH_SECRET=change-me-refresh-secret-32chars
ACCESS_TOKEN_EXPIRES=2h
REFRESH_TOKEN_EXPIRES=7d
# RSA 密钥对（PEM 格式，生产用 KMS 管理）
RSA_PRIVATE_KEY=change-me
RSA_PUBLIC_KEY=change-me
# 微信小程序
WX_APP_ID=
WX_APP_SECRET=
# 文件上传
UPLOAD_DIR=./uploads
# 跨域
CORS_ORIGIN=http://localhost:5173
